def dotted_path_is_valid(path: Any) -> bool:
    return isinstance(path, str) and bool(re.match(r"^[A-Za-z_][A-Za-z0-9_]*(\.[A-Za-z_][A-Za-z0-9_]*)*$", path))


def lint_pipeline(override_pipeline: Optional[Path] = None) -> int:
    pipeline_path = override_pipeline or locate_config(None, "pipeline.yaml")
    pipeline = load_yaml_file(pipeline_path)
    phases = phase_items(pipeline)
    phase_names_set = {name for name, _ in phases}
    errors: List[str] = []
    warnings: List[str] = []
    referenced: set[str] = set()

    for name, cfg in phases:
        verdicts = cfg.get("verdicts")
        if not isinstance(verdicts, dict) or not verdicts:
            errors.append(f"phase {name}: missing verdicts mapping")
            continue
        for verdict, rule in verdicts.items():
            if not isinstance(rule, dict):
                errors.append(f"phase {name} verdict {verdict}: rule must be mapping")
                continue
            nxt = rule.get("next")
            if nxt not in SPECIAL_NEXT and nxt not in phase_names_set:
                errors.append(f"phase {name} verdict {verdict}: next={nxt!r} does not reference a phase or special value")
            if nxt in phase_names_set:
                referenced.add(nxt)
            retry = rule.get("retry")
            if retry is not None:
                if not isinstance(retry, dict):
                    errors.append(f"phase {name} verdict {verdict}: retry must be mapping")
                else:
                    exhausted = retry.get("exhausted")
                    if exhausted not in SPECIAL_NEXT and exhausted not in phase_names_set:
                        errors.append(f"phase {name} verdict {verdict}: retry.exhausted={exhausted!r} invalid")
                    if exhausted in phase_names_set:
                        referenced.add(exhausted)

        for dotted in cfg.get("required_fields", []) or []:
            if not dotted_path_is_valid(dotted):
                errors.append(f"phase {name}: invalid required field path {dotted!r}")
        required_if_verdict = cfg.get("required_if_verdict", {}) or {}
        if isinstance(required_if_verdict, dict):
            verdicts_dict = cfg.get("verdicts", {}) or {}
            for verdict_val, fields in required_if_verdict.items():
                if verdict_val not in verdicts_dict:
                    errors.append(f"phase {name}: required_if_verdict.{verdict_val} is not a valid verdict")
                if not isinstance(fields, list):
                    errors.append(f"phase {name}: required_if_verdict.{verdict_val} must be a list")
                    continue
                for dotted in fields:
                    if not dotted_path_is_valid(dotted):
                        errors.append(f"phase {name}: invalid required_if_verdict.{verdict_val} path {dotted!r}")
        elif required_if_verdict:
            errors.append(f"phase {name}: required_if_verdict must be a mapping")
        verdict_field = cfg.get("verdict_field")
        if not dotted_path_is_valid(verdict_field):
            errors.append(f"phase {name}: invalid verdict_field {verdict_field!r}")

        inputs_cfg = cfg.get("inputs", {})
        if isinstance(inputs_cfg, dict):
            for group_key in ["required", "required_if_present"]:
                group = inputs_cfg.get(group_key, []) or []
                if not isinstance(group, list):
                    errors.append(f"phase {name}: inputs.{group_key} must be a list")
                    continue
                for ref_phase in group:
                    if ref_phase not in phase_names_set:
                        errors.append(f"phase {name}: inputs.{group_key} references non-existent phase: {ref_phase}")
                    else:
                        referenced.add(ref_phase)
        else:
            errors.append(f"phase {name}: inputs must be a mapping")

        model_policy = cfg.get("model_policy") or {}
        if isinstance(model_policy, dict):
            other = model_policy.get("family_must_differ_from")
            if other is not None and other not in phase_names_set:
                errors.append(f"phase {name}: model_policy.family_must_differ_from={other!r} is not a phase")
        else:
            errors.append(f"phase {name}: model_policy must be a mapping")

        approval_policy = cfg.get("approval_policy")
        if approval_policy == "never_if_schema_valid":
            normal_nexts = [rule.get("next") for rule in verdicts.values() if isinstance(rule, dict) and rule.get("next") in phase_names_set]
            if normal_nexts:
                warnings.append(f"phase {name}: approval_policy never_if_schema_valid on non-terminal phase")

    deposition = dict(phases).get("deposition")
    if deposition is not None and (not isinstance(deposition, dict) or deposition.get("optional") is not True):
        errors.append("deposition must be marked optional: true")

    # Check model assignments against registry
    models_yaml = load_yaml_file(locate_config(Path.cwd(), "models.yaml"))
    model_registry = load_model_registry(models_yaml)
    for name, cfg in phases:
        if cfg.get("optional"):
            continue
        assigned = cfg.get("model")
        if not assigned or not isinstance(assigned, str) or not assigned.strip():
            errors.append(f"phase {name}: missing or empty model assignment")
        elif assigned not in model_registry:
            errors.append(f"phase {name}: model {assigned!r} not in models.yaml")

    # Check top-level runtime policies
    tp = pipeline.get("timeout_policy")
    if isinstance(tp, dict):
        for key in ["max_retries", "retry_interval_seconds"]:
            if not isinstance(tp.get(key), int):
                errors.append(f"timeout_policy.{key} must be an integer")
        if tp.get("on_exhaustion") not in ("blocking_ex", None):
            errors.append(f"timeout_policy.on_exhaustion must be 'blocking_ex'")
    mf = pipeline.get("model_freshness")
    if isinstance(mf, dict):
        if not isinstance(mf.get("max_staleness_days"), int):
            errors.append("model_freshness.max_staleness_days must be an integer")
        if mf.get("on_stale") not in ("warning", "blocking"):
            errors.append("model_freshness.on_stale must be 'warning' or 'blocking'")
    vc = pipeline.get("verification_confidence")
    if isinstance(vc, dict):
        if not isinstance(vc.get("threshold"), (int, float)):
            errors.append("verification_confidence.threshold must be a number")
        if vc.get("on_low_confidence") not in ("info", "warning", "blocking"):
            errors.append("verification_confidence.on_low_confidence must be 'info', 'warning', or 'blocking'")

    for name, cfg in phases:
        if name not in referenced and not cfg.get("optional") and name != phases[0][0]:
            warnings.append(f"phase {name}: unused phase (not referenced by any verdict next/exhausted)")

    result = {
        "lint": {
            "pipeline": str(pipeline_path),
            "status": "FAIL" if errors else "PASS",
            "errors": errors,
            "warnings": warnings,
        }
    }
    print(json.dumps(result, indent=2))
    return 1 if errors else 0


# ---------------------------------------------------------------------------
# Execution ledger statistics
# ---------------------------------------------------------------------------

LEDGER_PATH = Path(
    os.environ.get("TOF_LEDGER_PATH", os.path.expanduser("~/.hermes/tof-execution-ledger.jsonl"))
)


def triage_stats(ledger_path: Path = LEDGER_PATH) -> int:
    if not ledger_path.exists():
        print("No execution records yet.")
        return 0

    entries: List[Dict[str, Any]] = []
    try:
        with ledger_path.open("r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if isinstance(entry, dict):
                    entries.append(entry)
    except OSError:
        print("No execution records yet.")
        return 0

    if not entries:
        print("No execution records yet.")
        return 0

    mode_counts: Dict[str, int] = {}
    error_count = 0
    for entry in entries:
        mode = str(entry.get("mode") or "unknown")
        mode_counts[mode] = mode_counts.get(mode, 0) + 1
        if str(entry.get("status") or "").upper() == "ERROR":
            error_count += 1

    full_seri_count = mode_counts.get("full-seri", 0)
    single_stage_count = sum(count for mode, count in mode_counts.items() if mode != "full-seri")

    print(f"Total executions: {len(entries)}")
    print("By mode:")
    print(f"  full-seri: {full_seri_count}")
    print(f"  single-stage: {single_stage_count}")
    for mode in sorted(mode_counts):
        if mode != "full-seri":
            print(f"  {mode}: {mode_counts[mode]}")
    print(f"ERROR: {error_count}")
    print("Last 10 entries:")
    print(f"{'timestamp':<32} {'mode':<20} {'status':<10}")
    for entry in entries[-10:]:
        timestamp = str(entry.get("timestamp", ""))
        mode = str(entry.get("mode", ""))
        status = str(entry.get("status", ""))
        print(f"{timestamp:<32} {mode:<20} {status:<10}")

    # Triage-advice statistics
    triage_entries = [e for e in entries if str(e.get("mode") or "") == "triage-advice"]
    if triage_entries:
        route_counts: Dict[str, int] = {}
        for e in triage_entries:
            r = str(e.get("route") or "unknown")
            route_counts[r] = route_counts.get(r, 0) + 1

        review_only_advice = route_counts.get("review-only", 0)
        actual_single_review = mode_counts.get("single-review", 0)

        print(f"\nTriage advice ({len(triage_entries)} recommendations):")
        for route in sorted(route_counts):
            print(f"  {route}: {route_counts[route]}")
        if review_only_advice > 0:
            ratio = actual_single_review / review_only_advice
            print(f"  → single-review dispatch rate vs triage review-only advice: {actual_single_review}/{review_only_advice} = {ratio:.1%}")
            print(f"     (explicit compliance rate within TOF; does not include chat-level self-execution outside tof run)")
    return 0


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(prog="tof", description="TOF P0 minimal validator/runtime")
    sub = parser.add_subparsers(dest="command", required=True)

    p_validate = sub.add_parser("validate", help="validate the latest TOF artifact in a run directory")
    p_validate.add_argument("run_dir", help="TOF run directory containing markdown artifacts")
    p_validate.add_argument("--fail-on", choices=["invalid", "blocking", "nonpass"], default=None)
    p_validate.add_argument("--pipeline", type=Path, default=None, help="explicit pipeline.yaml path")
    p_validate.add_argument("--models", type=Path, default=None, help="explicit models.yaml path")
    p_validate.add_argument("--allow-untrusted-audit", action="store_true", default=False,
                            help="bypass provenance gate; accept fixture/hand-written metadata")

    p_lint = sub.add_parser("lint-pipeline", help="check pipeline.yaml internal consistency")
    p_lint.add_argument("--pipeline", type=Path, default=None, help="explicit pipeline.yaml path")

    p_run = sub.add_parser("run", help="orchestrate a TOF run (receipt-driven loop)")
    p_run.add_argument("run_dir", help="TOF run directory")
    p_run.add_argument("--step", action="store_true", help="single-step, one phase only")
    p_run.add_argument("--only", type=str, default=None,
                       help="dispatch only this phase (e.g., review, scout, establish)")
    p_run.add_argument("--task", type=str, default=None, help="task description for the clarify phase")

    p_triage = sub.add_parser("triage", help="route a task to self-execution or TOF stage")
    p_triage.add_argument("task", type=str, help="task description (quote if multi-word)")

    sub.add_parser("triage-stats", help="show TOF execution ledger statistics")

    args = parser.parse_args(argv)

    if args.command == "validate":
        return validate_run(Path(args.run_dir).resolve(), fail_on=args.fail_on,
                           override_pipeline=args.pipeline,
                           override_models=args.models,
                           allow_untrusted_audit=args.allow_untrusted_audit)
    if args.command == "lint-pipeline":
        return lint_pipeline(override_pipeline=args.pipeline)
    if args.command == "run":
        from orchestrator import run as orch_run
        return orch_run(args.run_dir, step_mode=args.step, task=args.task,
                        only_phase=args.only)
    if args.command == "triage-stats":
        return triage_stats()
    if args.command == "triage":
        pipeline_path = locate_config(Path.cwd(), "pipeline.yaml")
        models_path = locate_config(Path.cwd(), "models.yaml")
        pipeline = load_yaml_file(pipeline_path)
        models_yaml = load_yaml_file(models_path)
        models = load_model_registry(models_yaml)
        tof_dir = pipeline_path.parent

        from orchestrator import run_triage
        try:
            result = run_triage(args.task, pipeline, models, tof_dir)
        except RuntimeError as e:
            print(f"error: {e}", file=sys.stderr)
            return 1
        print(json.dumps(result, indent=2))
        return 0
    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    sys.exit(main())
