# Main validation
# ---------------------------------------------------------------------------

def validate_run(run_dir: Path, fail_on: Optional[str] = None,
                override_pipeline: Optional[Path] = None,
                override_models: Optional[Path] = None,
                allow_untrusted_audit: bool = False) -> int:
    pipeline_path = override_pipeline or locate_config(run_dir, "pipeline.yaml")
    models_path = override_models or locate_config(run_dir, "models.yaml")
    pipeline = load_yaml_file(pipeline_path)
    pipeline_sha = file_sha256(pipeline_path)
    models_yaml = load_yaml_file(models_path)
    models_sha = file_sha256(models_path)
    models = load_model_registry(models_yaml)
    phases = phase_items(pipeline)
    phase_names = [name for name, _ in phases]
    phase_cfgs = {name: cfg for name, cfg in phases}

    # Model freshness check
    freshness_warnings: List[str] = []
    freshness_policy = pipeline.get("model_freshness", {})
    if isinstance(freshness_policy, dict):
        max_days = freshness_policy.get("max_staleness_days", 30)
        on_stale = freshness_policy.get("on_stale", "warning")
        now = _dt.datetime.now(_dt.timezone.utc).date()
        for mid, mdata in models_yaml.get("models", {}).items():
            checked = mdata.get("freshness_checked_at")
            if not checked:
                freshness_warnings.append(f"model {mid}: no freshness_checked_at date")
                continue
            try:
                checked_date = _dt.date.fromisoformat(str(checked))
                days = (now - checked_date).days
                if days > max_days:
                    msg = f"model {mid}: freshness_checked_at={checked} ({days}d ago, max={max_days}d)"
                    freshness_warnings.append(msg)
            except (ValueError, TypeError):
                freshness_warnings.append(f"model {mid}: invalid freshness_checked_at={checked}")

    artifacts = scan_artifacts(run_dir, pipeline)
    if not artifacts:
        first = next((name for name, cfg in phases if not cfg.get("optional")), phase_names[0])
        receipt = {
            "validation": {
                "id": validation_id(),
                "artifact": None,
                "phase": first,
                "verdict": None,
                "status": "PENDING",
                "next_allowed": [first],
                "reasons": ["no TOF artifacts found"],
                "checks": {},
                "config": {
                    "pipeline": {"path": str(pipeline_path), "sha256": pipeline_sha},
                    "models": {"path": str(models_path), "sha256": models_sha},
                },
            }
        }
        print(json.dumps(receipt, indent=2))
        return 0

    # Build indices
    by_path, by_phase, by_sha = build_indices(artifacts)
    grouped, latest_by_phase = group_artifacts(artifacts)

    # Resolve input edges
    resolve_ws = resolve_input_edges(artifacts, by_path, by_phase, by_sha)
    for w in resolve_ws:
        warn(w)

    # Pre-load session metadata for family resolution.
    # This allows resolve_family_for_artifact to prefer adapter-confirmed
    # actual_family over artifact self-reported values — closing the
    # self-attestation loop identified in Round 2 review #3.
    session_metadata: Dict[str, Dict[str, Any]] = {}
    for art in artifacts:
        meta_path = run_dir / f".session-metadata-{art.phase}.json"
        if meta_path.exists():
            try:
                session_metadata[art.phase] = json.loads(meta_path.read_text())
            except (json.JSONDecodeError, OSError):
                pass

    # Compute checks for all artifacts
    artifact_results: Dict[str, Any] = {}
    for art in artifacts:
        phase_cfg = phase_cfgs.get(art.phase)
        if phase_cfg is None:
            continue
        artifact_results[art.sha256] = compute_artifact_checks(
            art, phase_cfg, by_phase, latest_by_phase, models,
            session_metadata=session_metadata)

    # Apply session fallback detection (reads .session-metadata-*.json)
    apply_session_fallback(artifacts, run_dir, artifact_results, pipeline,
                           models=models, allow_untrusted_audit=allow_untrusted_audit)

    # Apply stale detection to all artifacts (writes back into artifact_results)
    apply_stale_to_all(artifacts, by_phase, artifact_results)

    # Unified cascade: ANY INVALID upstream → ALL dependents INVALID
    cascade_invalidation(artifacts, artifact_results)

    # Select current attempt via transition-aware resolution
    current_art = resolve_current_attempt(phase_names, phase_cfgs, latest_by_phase, by_phase, artifact_results)

    # Get current artifact's results
    cur_result = artifact_results.get(current_art.sha256, {})
    checks = dict(cur_result.get("checks", {}))
    status = cur_result.get("status", "UNKNOWN")
    verdict = cur_result.get("verdict")
    next_allowed = list(cur_result.get("next_allowed", []))
    reasons = list(cur_result.get("reasons", []))

    # INVALID → override transition
    if status == "INVALID":
        next_allowed = []
        required_action = "rerun_current_phase"
    else:
        required_action = None

    # Model freshness: if on_stale=blocking and any model is stale, mark INVALID
    if on_stale == "blocking" and freshness_warnings:
        status = "INVALID"
        next_allowed = []
        required_action = "rerun_current_phase"
        reasons.extend(f"freshness: {w}" for w in freshness_warnings)

    # Find causal frontier (stale now in artifact_results, frontier correctly excludes stale)
    frontier_status, frontier_art = find_causal_frontier(phase_names, artifact_results, by_phase, latest_by_phase)

    # Build receipt
    receipt: Dict[str, Any] = {
        "validation": {
            "id": validation_id(),
            "artifact": current_art.path.name,
            "phase": current_art.phase,
            "verdict": verdict,
            "status": status,
            "next_allowed": next_allowed,
            "reasons": reasons,
            "checks": checks,
        }
    }
    if status == "INVALID":
        receipt["validation"]["required_action"] = "rerun_current_phase"
    if frontier_art:
        receipt["validation"]["causal_frontier"] = {
            "artifact": frontier_art.path.name,
            "phase": frontier_art.phase,
            "status": frontier_status,
        }
    receipt["validation"]["config"] = {
        "pipeline": {"path": str(pipeline_path), "sha256": pipeline_sha},
        "models": {"path": str(models_path), "sha256": models_sha},
    }
    if freshness_warnings:
        receipt["validation"]["freshness_warnings"] = freshness_warnings

    print(json.dumps(receipt, indent=2))

    if fail_on == "invalid" and status == "INVALID":
        return 1
    if fail_on == "blocking" and status in {"INVALID", "BLOCKING"}:
        return 1
    if fail_on == "nonpass" and status != "PASS":
        return 1
    return 0


