try:
    import yaml
except ImportError:
    print("error: PyYAML is required (import yaml failed)", file=sys.stderr)
    sys.exit(2)

SPECIAL_NEXT = {None, "pause", "escalation", "exploration"}
PASSISH_VERDICTS = {"PASS", "READY", "DONE"}


# ---------------------------------------------------------------------------
# Data structures
# ---------------------------------------------------------------------------

@dataclass
class InputRef:
    """A single input reference from tof.inputs[] in artifact frontmatter."""
    declared_phase: str
    sha256: str
    path: Optional[str] = None
    resolved: Optional["Artifact"] = None
    valid: bool = False
    reason: str = ""


@dataclass
class Artifact:
    path: Path
    frontmatter: Dict[str, Any]
    content: str
    phase: str
    round: int
    sha256: str
    inputs: List[InputRef] = field(default_factory=list)


# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

def die(message: str, code: int = 2) -> None:
    print(f"error: {message}", file=sys.stderr)
    sys.exit(code)


def warn(message: str) -> None:
    print(f"warning: {message}", file=sys.stderr)


def load_yaml_file(path: Path) -> Dict[str, Any]:
    try:
        with path.open("r", encoding="utf-8") as f:
            data = yaml.safe_load(f) or {}
    except FileNotFoundError:
        die(f"missing file: {path}")
    except yaml.YAMLError as e:
        die(f"invalid YAML in {path}: {e}")
    except OSError as e:
        die(f"cannot read {path}: {e}")
    if not isinstance(data, dict):
        die(f"YAML root must be a mapping: {path}")
    return data


def candidate_config_paths(run_dir: Optional[Path], filename: str) -> List[Path]:
    paths: List[Path] = []
    if run_dir is not None:
        paths.append((run_dir / ".tof" / filename).resolve())   # snapshot (highest priority)
        paths.append((run_dir / filename).resolve())              # run dir itself (fixture-local)
        paths.append((run_dir / ".." / filename).resolve())      # parent dir
    paths.append((Path.cwd() / filename).resolve())
    tof_dir = os.environ.get("TOF_DIR")
    if tof_dir:
        paths.append((Path(tof_dir) / filename).resolve())
    paths.append((Path(__file__).resolve().parent / filename).resolve())
    deduped: List[Path] = []
    seen = set()
    for p in paths:
        if str(p) not in seen:
            seen.add(str(p))
            deduped.append(p)
    return deduped


def locate_config(run_dir: Optional[Path], filename: str) -> Path:
    for p in candidate_config_paths(run_dir, filename):
        if p.exists():
            return p
    checked = ", ".join(str(p) for p in candidate_config_paths(run_dir, filename))
    die(f"could not locate {filename}; checked: {checked}")
    raise AssertionError("unreachable")


def phase_items(pipeline: Dict[str, Any]) -> List[Tuple[str, Dict[str, Any]]]:
    phases = pipeline.get("phases")
    if not isinstance(phases, dict) or not phases:
        die("pipeline.yaml must contain a non-empty 'phases' mapping")
    return [(name, cfg) for name, cfg in phases.items() if name != "triage"]


def get_path(obj: Any, dotted: str) -> Any:
    cur = obj
    for part in dotted.split("."):
        if not part:
            raise KeyError(dotted)
        if isinstance(cur, dict) and part in cur:
            cur = cur[part]
        else:
            raise KeyError(dotted)
    return cur


def has_nonempty_path(obj: Any, dotted: str) -> bool:
    try:
        value = get_path(obj, dotted)
    except KeyError:
        return False
    if value is None:
        return False
    if isinstance(value, str) and value.strip() == "":
        return False
    if isinstance(value, (list, dict)) and len(value) == 0:
        return False
    return True


def is_nonempty(value: Any) -> bool:
    if value is None:
        return False
    if isinstance(value, str):
        return value.strip() != ""
    if isinstance(value, (list, dict)):
        return len(value) > 0
    return True


def file_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def validation_id() -> str:
    return "val_" + _dt.datetime.utcnow().strftime("%Y%m%d_%H%M%S_%f")


# ---------------------------------------------------------------------------
# Frontmatter parsing
# ---------------------------------------------------------------------------

def parse_frontmatter(path: Path) -> Optional[Tuple[Dict[str, Any], str]]:
    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        warn(f"skipping non-UTF8 markdown file: {path}")
        return None
    except OSError as e:
        warn(f"skipping unreadable markdown file {path}: {e}")
        return None

    lines = text.splitlines(keepends=True)
    if not lines or lines[0].strip() != "---":
        return None
    end_idx = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            end_idx = i
            break
    if end_idx is None:
        warn(f"skipping markdown with unterminated frontmatter: {path}")
        return None

    raw_fm = "".join(lines[1:end_idx])
    body = "".join(lines[end_idx + 1 :])
    try:
        fm = yaml.safe_load(raw_fm) or {}
    except yaml.YAMLError as e:
        warn(f"skipping markdown with invalid YAML frontmatter {path}: {e}")
        return None
    if not isinstance(fm, dict):
        warn(f"skipping markdown with non-mapping frontmatter: {path}")
        return None
    return fm, body


def parse_input_refs(fm: Dict[str, Any]) -> List[InputRef]:
    """Parse tof.inputs from artifact frontmatter into InputRef objects."""
    tof = fm.get("tof")
    if not isinstance(tof, dict):
        return []
    raw = tof.get("inputs", [])
    if not isinstance(raw, list):
        return []
    refs: List[InputRef] = []
    for item in raw:
        if not isinstance(item, dict):
            continue
        phase = item.get("phase")
        sha = item.get("sha256")
        if not phase or not sha:
            continue
        refs.append(InputRef(
            declared_phase=str(phase),
            sha256=str(sha),
            path=str(item["path"]) if "path" in item and item["path"] else None,
        ))
    return refs


# ---------------------------------------------------------------------------
# Scanning & indexing
# ---------------------------------------------------------------------------

def scan_artifacts(run_dir: Path, pipeline: Dict[str, Any]) -> List[Artifact]:
    phases = {name for name, _cfg in phase_items(pipeline)}
    artifacts: List[Artifact] = []
    if not run_dir.exists():
        die(f"run directory does not exist: {run_dir}")
    if not run_dir.is_dir():
        die(f"run path is not a directory: {run_dir}")

    for path in sorted(run_dir.glob("*.md")):
        parsed = parse_frontmatter(path)
        if parsed is None:
            continue
        fm, body = parsed
        tof = fm.get("tof")
        if not isinstance(tof, dict):
            continue
        phase = tof.get("phase")
        if phase not in phases:
            continue
        round_raw = tof.get("round", 1)
        try:
            round_num = int(round_raw)
        except (TypeError, ValueError):
            round_num = 1
        refs = parse_input_refs(fm)
        artifacts.append(Artifact(
            path=path,
            frontmatter=fm,
            content=body,
            phase=phase,
            round=round_num,
            sha256=file_sha256(path),
            inputs=refs,
        ))
    return artifacts


def build_indices(artifacts: List[Artifact]) -> Tuple[Dict[str, Artifact], Dict[str, List[Artifact]], Dict[str, List[Artifact]]]:
    by_path: Dict[str, Artifact] = {}
    by_phase: Dict[str, List[Artifact]] = {}
    by_sha: Dict[str, List[Artifact]] = {}
    for art in artifacts:
        by_path[str(art.path.resolve())] = art
        by_phase.setdefault(art.phase, []).append(art)
        by_sha.setdefault(art.sha256, []).append(art)
    for items in by_phase.values():
        items.sort(key=lambda a: (a.round, a.path.stat().st_mtime, a.path.name))
    return by_path, by_phase, by_sha


def group_artifacts(artifacts: Iterable[Artifact]) -> Tuple[Dict[str, List[Artifact]], Dict[str, Artifact]]:
    grouped: Dict[str, List[Artifact]] = {}
    latest: Dict[str, Artifact] = {}
    for art in artifacts:
        grouped.setdefault(art.phase, []).append(art)
    for phase, items in grouped.items():
        items.sort(key=lambda a: (a.round, a.path.stat().st_mtime, a.path.name))
        latest[phase] = items[-1]
    return grouped, latest


# ---------------------------------------------------------------------------
# Input edge resolution (P0.2a core)
# ---------------------------------------------------------------------------

def resolve_input_edges(artifacts: List[Artifact], by_path: Dict[str, Artifact],
                        by_phase: Dict[str, List[Artifact]], by_sha: Dict[str, List[Artifact]]) -> List[str]:
    """Resolve each artifact's InputRefs to target Artifact nodes.
    
    For each input ref:
    - If `path` specified: target must exist, be a TOF artifact, phase must match, sha256 must match
    - If no `path`: match by (phase + sha256) in by_sha
    - Detects: self-reference, duplicate phase, phase mismatch, sha mismatch
    
    Returns warnings list (non-fatal issues).
    """
    warnings: List[str] = []
    
    for art in artifacts:
        seen_phases: set[str] = set()
        for ref in art.inputs:
            # --- Self-reference check ---
            if ref.path:
                target_abs = (art.path.parent / ref.path).resolve()
                if target_abs == art.path.resolve():
                    ref.valid = False
                    ref.reason = "self-reference: input path points to own artifact"
                    continue
            
            # --- Duplicate phase check ---
            if ref.declared_phase in seen_phases:
                ref.valid = False
                ref.reason = f"duplicate phase reference: {ref.declared_phase}"
                continue
            seen_phases.add(ref.declared_phase)
            
            if ref.path:
                # --- Path-based resolution ---
                target_path = (art.path.parent / ref.path).resolve()
                if not target_path.exists():
                    ref.valid = False
                    ref.reason = f"input path not found: {ref.path}"
                    continue
                target = by_path.get(str(target_path))
                if target is None:
                    ref.valid = False
                    ref.reason = f"path exists but is not a TOF artifact: {ref.path}"
                    continue
                if target.phase != ref.declared_phase:
                    ref.valid = False
                    ref.reason = (f"input phase mismatch: declared={ref.declared_phase} "
                                  f"but {ref.path} has phase={target.phase}")
                    continue
                if target.sha256 != ref.sha256:
                    ref.valid = False
                    ref.reason = f"sha256 mismatch for {ref.path}"
                    continue
                ref.resolved = target
                ref.valid = True
            else:
                # --- Phase+sha resolution (no path) ---
                candidates = by_sha.get(ref.sha256, [])
                phase_candidates = [c for c in candidates if c.phase == ref.declared_phase]
                if not phase_candidates:
                    ref.valid = False
                    ref.reason = (f"no artifact found for phase={ref.declared_phase} "
                                  f"with matching sha256={ref.sha256[:16]}...")
                    continue
                if len(phase_candidates) > 1:
                    warnings.append(
                        f"{art.path.name}: multiple artifacts match phase={ref.declared_phase} "
                        f"sha256={ref.sha256[:16]}...; using first"
                    )
                ref.resolved = phase_candidates[0]
                ref.valid = True
    
    return warnings


# ---------------------------------------------------------------------------
# Model registry helpers
# ---------------------------------------------------------------------------

def load_model_registry(models_yaml: Dict[str, Any]) -> Dict[str, Dict[str, Any]]:
    models = models_yaml.get("models", {})
    if not isinstance(models, dict):
        return {}
    return models


def produced_by(fm: Dict[str, Any]) -> Dict[str, Any]:
    tof = fm.get("tof")
    if not isinstance(tof, dict):
        return {}
    pb = tof.get("produced_by")
    return pb if isinstance(pb, dict) else {}


def resolve_family_for_artifact(art: Artifact, models: Dict[str, Dict[str, Any]],
                                session_metadata: Optional[Dict[str, Dict[str, Any]]] = None) -> Tuple[Optional[str], Optional[str]]:
    """Return (family, error). Registry is authority; session metadata preferred over artifact self-report."""
    pb = produced_by(art.frontmatter)
    model_id = pb.get("assigned_model") or pb.get("claimed_model")
    if model_id and model_id not in models:
        return None, f"unknown model family for model_id={model_id}"

    registry_family = models.get(model_id, {}).get("family") if model_id else None

    # P2.x: prefer session metadata actual_family (adapter-confirmed)
    # over artifact self-reported actual_family.
    if session_metadata and art.phase in session_metadata:
        meta = session_metadata[art.phase]
        method = meta.get("method") or meta.get("verification_method", "unverified")
        if method in ("adapter_confirmed", "log_parsed"):
            meta_family = meta.get("actual_family")
            if meta_family:
                if registry_family and str(meta_family) != str(registry_family):
                    return None, (
                        f"session audit family={meta_family} != "
                        f"registry family={registry_family} for {model_id}"
                    )
                return str(meta_family), None

    actual_family = pb.get("actual_family")

    if actual_family and registry_family:
        if str(actual_family) != str(registry_family):
            return None, (
                f"model family mismatch: assigned_model={model_id} "
                f"registry_family={registry_family} but artifact claims actual_family={actual_family}"
            )
        return str(actual_family), None

    if registry_family:
        return str(registry_family), None
    # Safety: if model_id is not in registry, we CANNOT trust artifact self-reported actual_family.
    # Artifact frontmatter is evidence, not authority — only adapter-verified facts can establish family.
    return None, f"cannot determine model family: assigned_model={model_id} not in registry and no adapter facts available"


# ---------------------------------------------------------------------------
# Per-artifact validation checks
# ---------------------------------------------------------------------------

def compute_artifact_checks(art: Artifact, phase_cfg: Dict[str, Any],
                            by_phase: Dict[str, List[Artifact]],
                            latest_by_phase: Dict[str, Artifact],
                            models: Dict[str, Dict[str, Any]],
                            session_metadata: Optional[Dict[str, Dict[str, Any]]] = None) -> Dict[str, Any]:
    """Compute all checks for a single artifact. Returns {checks, reasons, status, verdict}."""
    reasons: List[str] = []
    checks: Dict[str, str] = {}

    # Forbidden next_allowed field
    forbidden_paths = find_forbidden_next_allowed(art.frontmatter)
    for p in forbidden_paths:
        warn(f"{art.path.name}: frontmatter field '{p}' is evidence, not authority; ignoring")
        reasons.append(f"ignored artifact-declared {p}; transition derived from pipeline.yaml")

    checks["schema"] = validate_schema(art, phase_cfg, reasons)
    checks["input_linkage"] = validate_input_linkage(art, phase_cfg, by_phase, reasons)
    checks["model_policy"] = validate_model_policy(art, phase_cfg, latest_by_phase, models, reasons, session_metadata)

    # Verdict
    try:
        verdict = str(get_path(art.frontmatter, str(phase_cfg.get("verdict_field"))))
    except KeyError:
        verdict = None

    any_check_blocking = any(v in {"FAIL", "BLOCKING"} for v in checks.values())

    if any_check_blocking:
        status = "INVALID"
    elif verdict in {"BLOCKING", "FAIL"}:
        status = "BLOCKING"
    elif verdict in PASSISH_VERDICTS:
        status = "PASS"
    else:
        status = verdict or "UNKNOWN"

    # Transition / retry only for valid artifacts
    next_allowed: List[Any] = []
    if not any_check_blocking and verdict in {"BLOCKING", "FAIL"} | PASSISH_VERDICTS:
        checks_real = dict(checks)
        checks_real["transition"], next_allowed = derive_transition(art, phase_cfg, by_phase, reasons)
        checks_real["retry_budget"], next_allowed = validate_retry_budget(art, phase_cfg, by_phase, next_allowed, reasons)
        checks = checks_real

    return {
        "checks": checks,
        "status": status,
        "verdict": verdict,
        "next_allowed": next_allowed,
        "reasons": reasons,
    }


def validate_schema(art: Artifact, phase_cfg: Dict[str, Any], reasons: List[str]) -> str:
    ok = True
    field_rules = phase_cfg.get("field_rules", {}) or {}
    if not isinstance(field_rules, dict):
        field_rules = {}

    for dotted in phase_cfg.get("required_fields", []) or []:
        if not isinstance(dotted, str):
            continue
        rules = field_rules.get(dotted, {}) or {}
        allow_empty = rules.get("allow_empty", False)
        if allow_empty:
            try:
                get_path(art.frontmatter, dotted)
            except KeyError:
                ok = False
                reasons.append(f"missing required field: {dotted}")
        elif not has_nonempty_path(art.frontmatter, dotted):
            ok = False
            reasons.append(f"missing or empty required field: {dotted}")

    # required_if_verdict: conditional fields only required for specific verdicts
    verdict_field = phase_cfg.get("verdict_field")
    declared_verdict = None
    if verdict_field:
        try:
            declared_verdict = str(get_path(art.frontmatter, str(verdict_field)))
        except KeyError:
            pass
    required_if_verdict = phase_cfg.get("required_if_verdict", {}) or {}
    if isinstance(required_if_verdict, dict) and declared_verdict:
        conditional_fields = required_if_verdict.get(declared_verdict, []) or []
        for dotted in conditional_fields:
            if not isinstance(dotted, str) or not has_nonempty_path(art.frontmatter, dotted):
                ok = False
                reasons.append(f"missing or empty required field for verdict={declared_verdict}: {dotted}")

    # --- Echo detection: FILL WITH tokens remaining in frontmatter ---
    if _check_echo(art, reasons):
        ok = False

    if field_rules:
        for dotted, rules in field_rules.items():
            if not isinstance(rules, dict):
                continue
            try:
                value = get_path(art.frontmatter, dotted)
            except KeyError:
                ok = False
                reasons.append(f"field rule target missing: {dotted}")
                continue
            if "min_items" in rules:
                min_items = int(rules["min_items"])
                if not hasattr(value, "__len__") or isinstance(value, (str, bytes)) or len(value) < min_items:
                    ok = False
                    actual = len(value) if hasattr(value, "__len__") and not isinstance(value, (str, bytes)) else "non-list"
                    reasons.append(f"{dotted}.min_items={min_items} failed (actual={actual})")

    verdict_field = phase_cfg.get("verdict_field")
    verdicts = phase_cfg.get("verdicts", {}) or {}
    if not isinstance(verdict_field, str):
        ok = False
        reasons.append("phase has no verdict_field in pipeline.yaml")
    else:
        try:
            verdict = get_path(art.frontmatter, verdict_field)
        except KeyError:
            ok = False
            reasons.append(f"missing verdict field: {verdict_field}")
        else:
            if not is_nonempty(verdict):
                ok = False
                reasons.append(f"empty verdict field: {verdict_field}")
            elif str(verdict) not in verdicts:
                ok = False
                valid = ", ".join(str(v) for v in verdicts.keys())
                reasons.append(f"invalid verdict {verdict_field}={verdict!r}; valid: {valid}")
    return "PASS" if ok else "BLOCKING"


def _check_echo(art: Artifact, reasons: List[str]) -> bool:
    """Detect echo: any frontmatter value containing unreplaced template markers.

    After _preprocess_prompt, legitimate templates become {{FIELD: ...}} or
    {{SHA_WILL_BE_INJECTED}} markers. If these survive into the artifact
    frontmatter, the model echoed the template back instead of filling it in.
    """
    found: List[str] = []
    def _scan(obj: Any, path: str = "") -> None:
        if isinstance(obj, dict):
            for k, v in obj.items():
                _scan(v, f"{path}.{k}" if path else k)
        elif isinstance(obj, list):
            for i, item in enumerate(obj):
                _scan(item, f"{path}[{i}]")
        elif isinstance(obj, str) and ("{{FIELD:" in obj or "{{SHA_" in obj):
            found.append(f"echo: {path}=\"{obj[:80]}\"")
    _scan(art.frontmatter)
    for e in found:
        reasons.append(e)
    return len(found) > 0


def derive_transition(art: Artifact, phase_cfg: Dict[str, Any],
                      grouped: Dict[str, List[Artifact]],
                      reasons: List[str]) -> Tuple[str, List[Any]]:
    verdict_field = phase_cfg.get("verdict_field")
    verdicts = phase_cfg.get("verdicts", {}) or {}
    try:
        verdict = str(get_path(art.frontmatter, str(verdict_field)))
    except KeyError:
        return "BLOCKING", []
    rule = verdicts.get(verdict)
    if not isinstance(rule, dict):
        return "BLOCKING", []

    next_value = rule.get("next")
    retry = rule.get("retry")
    if retry:
        try:
            max_rounds = int(retry.get("max_rounds"))
        except (TypeError, ValueError):
            reasons.append(f"retry policy for {art.phase}.{verdict} has invalid max_rounds")
            return "BLOCKING", []
        retry_count = len(grouped.get(art.phase, []))
        exhausted = retry.get("exhausted")
        if retry_count >= max_rounds:
            next_value = exhausted
            reasons.append(f"retry_count={retry_count} >= max_rounds={max_rounds}; exhausted routes to {exhausted}")
        else:
            reasons.append(f"retry_count={retry_count} < max_rounds={max_rounds}")
    reasons.append(f"{phase_cfg.get('verdict_field')}={verdict} routes to {next_value}")
    if next_value is None:
        return "PASS", []
    return "PASS", [next_value]


def validate_input_linkage(art: Artifact, phase_cfg: Dict[str, Any],
                           by_phase: Dict[str, List[Artifact]],
                           reasons: List[str]) -> str:
    """Check pipeline.yaml input requirements against resolved InputRefs.

    All refs must be resolved and valid. Uses pre-computed InputRef.valid flags
    set by resolve_input_edges().
    """
    inputs_cfg = phase_cfg.get("inputs", {})
    if inputs_cfg in (None, {}):
        inputs_cfg = {}
    if not isinstance(inputs_cfg, dict):
        return "PASS"

    ok = True

    # Collect refs by phase (list — preserves duplicates for error reporting)
    refs_by_phase: Dict[str, List[InputRef]] = {}
    for ref in art.inputs:
        if ref.declared_phase:
            refs_by_phase.setdefault(ref.declared_phase, []).append(ref)

    # Detect duplicate phase refs
    for phase, refs in refs_by_phase.items():
        if len(refs) > 1:
            ok = False
            reasons.append(f"input linkage: duplicate phase reference '{phase}' — exactly one input per phase required")

    # Check required
    for req_phase in inputs_cfg.get("required", []) or []:
        req_phase = str(req_phase)
        if req_phase not in refs_by_phase:
            ok = False
            reasons.append(f"input linkage missing required upstream: {req_phase}")
            continue
        for ref in refs_by_phase[req_phase]:
            if not ref.valid:
                ok = False
                reasons.append(f"input linkage for {req_phase}: {ref.reason}")

    # Check required_if_present
    for req_if_phase in inputs_cfg.get("required_if_present", []) or []:
        req_if_phase = str(req_if_phase)
        # Does this phase have any artifact in the run?
        if req_if_phase not in by_phase:
            continue
        # Phase exists — must be referenced
        if req_if_phase not in refs_by_phase:
            ok = False
            reasons.append(f"input linkage: phase={req_if_phase} exists in run but not referenced (required_if_present)")
            continue
        for ref in refs_by_phase[req_if_phase]:
            if not ref.valid:
                ok = False
                reasons.append(f"input linkage for {req_if_phase}: {ref.reason}")

    return "PASS" if ok else "BLOCKING"


def validate_model_policy(art: Artifact, phase_cfg: Dict[str, Any],
                          latest_by_phase: Dict[str, Artifact],
                          models: Dict[str, Dict[str, Any]],
                          reasons: List[str],
                          session_metadata: Optional[Dict[str, Dict[str, Any]]] = None) -> str:
    policy = phase_cfg.get("model_policy") or {}
    if not isinstance(policy, dict) or not policy:
        return "PASS"
    ok = True
    if "family_must_differ_from" in policy:
        other_phase = str(policy["family_must_differ_from"])
        other = latest_by_phase.get(other_phase)
        if other is None:
            reasons.append(f"model policy cannot find phase={other_phase}")
            return "BLOCKING"
        cur_family, cur_error = resolve_family_for_artifact(art, models, session_metadata)
        other_family, other_error = resolve_family_for_artifact(other, models, session_metadata)
        if cur_error:
            ok = False
            reasons.append(cur_error)
        if other_error:
            ok = False
            reasons.append(other_error)
        if cur_family and other_family and cur_family == other_family:
            ok = False
            reasons.append(f"model family must differ from {other_phase} (both {cur_family})")
        elif cur_family and other_family:
            reasons.append(f"model family differs from {other_phase}: {cur_family} != {other_family}")
    return "PASS" if ok else "BLOCKING"


def validate_retry_budget(art: Artifact, phase_cfg: Dict[str, Any],
                          grouped: Dict[str, List[Artifact]],
                          next_allowed: List[Any],
                          reasons: List[str]) -> Tuple[str, List[Any]]:
    verdict_field = phase_cfg.get("verdict_field")
    verdicts = phase_cfg.get("verdicts", {}) or {}
    try:
        verdict = str(get_path(art.frontmatter, str(verdict_field)))
    except KeyError:
        return "BLOCKING", next_allowed
    rule = verdicts.get(verdict)
    if not isinstance(rule, dict) or "retry" not in rule:
        return "PASS", next_allowed
    retry = rule["retry"] or {}
    try:
        max_rounds = int(retry.get("max_rounds"))
    except (TypeError, ValueError):
        return "BLOCKING", next_allowed
    count = len(grouped.get(art.phase, []))
    if count >= max_rounds:
        exhausted = retry.get("exhausted")
        reasons.append(f"retry budget exhausted: count={count} >= max_rounds={max_rounds}; next_allowed={exhausted}")
        return "PASS", ([] if exhausted is None else [exhausted])
    return "PASS", next_allowed


def find_forbidden_next_allowed(obj: Any, prefix: str = "") -> List[str]:
    found: List[str] = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            key_path = f"{prefix}.{k}" if prefix else str(k)
            if k == "next_allowed":
                found.append(key_path)
            found.extend(find_forbidden_next_allowed(v, key_path))
    elif isinstance(obj, list):
        for i, v in enumerate(obj):
            found.extend(find_forbidden_next_allowed(v, f"{prefix}[{i}]"))
    return found


