# Stale detection & frontier (P0.2a core)
# ---------------------------------------------------------------------------

def find_causal_frontier(phase_names: List[str], artifact_results: Dict[str, Any],
                          by_phase: Dict[str, List[Artifact]],
                          latest_by_phase: Dict[str, Artifact]) -> Tuple[Optional[str], Optional[Artifact]]:
    """Find the latest causal-valid artifact frontier.
    
    An artifact is causal-valid if:
    - Its checks all PASS (status PASS or BLOCKING, not INVALID)
    - All required upstream inputs are resolved and valid
    
    Returns (status_string, artifact) where status_string is the frontier's status
    or None if no valid frontier exists.
    """
    # For P0.2a: find the latest phase (by DAG order) that has a valid artifact
    frontier_art: Optional[Artifact] = None
    frontier_status: Optional[str] = None
    
    for phase in reversed(phase_names):
        latest = latest_by_phase.get(phase)
        if latest is None:
            continue
        result = artifact_results.get(latest.sha256)
        if result is None:
            continue
        st = result.get("status")
        if st == "INVALID":
            # Check if there's an earlier round that's valid
            revisions = by_phase.get(phase, [])
            for art in reversed(revisions):
                r = artifact_results.get(art.sha256)
                if r and r.get("status") != "INVALID" and r.get("status") != "UNKNOWN":
                    frontier_art = art
                    frontier_status = r["status"]
                    break
        else:
            frontier_art = latest
            frontier_status = st
        if frontier_art:
            break
    
    return frontier_status, frontier_art


def check_stale(current_art: Artifact, by_phase: Dict[str, List[Artifact]],
                artifact_results: Dict[str, Any]) -> Tuple[bool, List[str]]:
    """Check if current_art references stale upstream artifacts.
    
    Returns (is_stale, reasons).
    An artifact is stale if any of its input refs points to an upstream phase
    that has a newer artifact which is itself valid (not INVALID).
    """
    stale_reasons: List[str] = []
    for ref in current_art.inputs:
        if not ref.valid or not ref.resolved:
            continue
        phase = ref.declared_phase
        revisions = by_phase.get(phase, [])
        for candidate in reversed(revisions):
            if candidate is ref.resolved:
                break  # no newer revision
            if candidate.round <= ref.resolved.round and candidate.path == ref.resolved.path:
                continue
            # This is a newer artifact. Is it valid?
            cres = artifact_results.get(candidate.sha256)
            if cres and cres.get("status") not in ("INVALID", "UNKNOWN", None):
                # Newer valid artifact exists with different content
                if candidate.sha256 != ref.sha256:
                    return True, [
                        f"stale downstream: {current_art.path.name} references "
                        f"{ref.declared_phase} round {ref.resolved.round}, but phase has newer "
                        f"valid artifact (round {candidate.round}) with different content"
                    ]
                else:
                    # Same content, idempotent re-run — not stale
                    break
    return False, stale_reasons


def apply_stale_to_all(artifacts: List[Artifact], by_phase: Dict[str, List[Artifact]],
                       artifact_results: Dict[str, Any]) -> None:
    """Run stale detection for all artifacts, writing results into artifact_results.
    
    STALE artifacts are marked INVALID in artifact_results — making them excluded
    from causal_frontier naturally.
    """
    for art in artifacts:
        if art.sha256 not in artifact_results:
            continue
        result = artifact_results[art.sha256]
        # Only check artifacts that aren't already INVALID from other checks
        if result.get("status") == "INVALID":
            continue
        is_stale, s_reasons = check_stale(art, by_phase, artifact_results)
        if is_stale:
            result["checks"]["stale"] = "BLOCKING"
            result["status"] = "INVALID"
            result["reasons"].extend(s_reasons)


def apply_session_fallback(artifacts: List[Artifact], run_dir: Path,
                           artifact_results: Dict[str, Any],
                           pipeline: Dict[str, Any],
                           models: Optional[Dict[str, Dict[str, Any]]] = None,
                           allow_untrusted_audit: bool = False) -> None:
    """Read .session-metadata-*.json files and apply outcome-driven validation.

    P0 provenance gate: metadata from untrusted sources (fixture, unverified,
    self_reported without registry backing) is rejected unless
    allow_untrusted_audit=True.

    Outcome mapping (after gate passes):
    - verified_match → no action (trust chain intact)
    - verified_mismatch / unknown_model → INVALID (trust broken)
    - unverified / unavailable / exception → BLOCKING (cannot verify)
    - no metadata file → BLOCKING (audit gap)

    For adapter_confirmed / log_parsed methods, cross-validates actual_model
    vs assigned_model and actual_family vs artifact self-reported family.

    This is fail-closed: any non-verified_match outcome blocks or invalidates.

    Exemption: phases with approval_policy='always' (e.g. clarify) skip audit
    because they are human-produced, not OT-dispatched.
    """
    phases_cfg = pipeline.get("phases", {})

    for art in artifacts:
        if art.sha256 not in artifact_results:
            continue
        result = artifact_results[art.sha256]
        if result.get("status") == "INVALID":
            # Intentional short-circuit: INVALID artifacts have already failed
            # schema, input_linkage, or model_policy checks. Session audit
            # cannot reverse an INVALID verdict — it can only add additional
            # reasons. Skipping saves work without weakening the trust chain.
            continue

        # Exempt human-produced phases from session audit
        phase_cfg = phases_cfg.get(art.phase, {})
        if phase_cfg.get("approval_policy") == "always":
            result["checks"]["session_audit"] = "NA"
            continue

        meta_path = run_dir / f".session-metadata-{art.phase}.json"
        if not meta_path.exists():
            result["checks"]["session_audit"] = "BLOCKING"
            result["status"] = "BLOCKING"
            result.setdefault("reasons", []).append(
                f"session audit: no metadata file for phase '{art.phase}' — "
                f"audit never ran or metadata was lost"
            )
            continue
        try:
            meta = json.loads(meta_path.read_text())

            # ================================================================
            # P0.1 — PROVENANCE GATE
            # Distinguish trusted evidence (adapter_confirmed/log_parsed from
            # real OT dispatch) from untrusted evidence (fixture/hand-written/
            # self_reported without registry backing).
            # ================================================================
            method = meta.get("method") or meta.get("verification_method", "unverified")

            if not allow_untrusted_audit:
                if method in ("fixture", "unverified"):
                    result["checks"]["session_audit"] = "BLOCKING"
                    result["status"] = "BLOCKING"
                    result.setdefault("reasons", []).append(
                        f"session audit: untrusted evidence source "
                        f"(method={method}) — metadata was not produced by "
                        f"an OT dispatch trace. Use --allow-untrusted-audit "
                        f"to bypass this gate for fixture/testing scenarios."
                    )
                    continue

                if method == "self_reported":
                    assigned = meta.get("assigned_model", "")
                    dv = "unverified"
                    if models and assigned in models:
                        dv = str(models[assigned].get(
                            "default_verification", "unverified"))
                    if dv != "self_reported":
                        result["checks"]["session_audit"] = "BLOCKING"
                        result["status"] = "BLOCKING"
                        result.setdefault("reasons", []).append(
                            f"session audit: self-reported identity not "
                            f"trusted — model={assigned} "
                            f"default_verification={dv}"
                        )
                        continue

            # ================================================================
            # P0.1b + P0.2 — CROSS-VALIDATION for trusted methods
            # When evidence comes from a trusted source, cross-check that
            # actual_model matches assigned_model, and that actual_family
            # is consistent with the artifact's self-reported family.
            # ================================================================
            if method in ("adapter_confirmed", "log_parsed"):
                actual_model = meta.get("actual_model", "")
                assigned_model = meta.get("assigned_model", "")
                if (actual_model and assigned_model
                        and actual_model != assigned_model
                        and meta.get("outcome") == "verified_match"):
                    result["checks"]["session_audit"] = "BLOCKING"
                    result["status"] = "INVALID"
                    result.setdefault("reasons", []).append(
                        f"session audit: metadata contradiction — "
                        f"outcome=verified_match but "
                        f"assigned_model={assigned_model} != "
                        f"actual_model={actual_model}"
                    )
                    continue

                # P0.2: family override — prefer session audit actual_family
                # over artifact self-reported actual_family
                meta_family = meta.get("actual_family")
                if meta_family:
                    pb = produced_by(art.frontmatter)
                    art_family = pb.get("actual_family")
                    if (art_family
                            and str(art_family) != str(meta_family)):
                        result["checks"]["model_policy"] = "BLOCKING"
                        if result.get("status") == "PASS":
                            result["status"] = "BLOCKING"
                        result.setdefault("reasons", []).append(
                            f"model policy: artifact self-reports "
                            f"actual_family={art_family} but session audit "
                            f"found actual_family={meta_family} "
                            f"(actual_model={actual_model})"
                        )

                # P1.3: provenance check — for trusted methods, require
                # that the artifact body hash was found in OT stdout.
                # This is the only mechanical defense against FM-1
                # (orchestrator writing artifacts without real dispatch).
                provenance = meta.get("provenance_verified")
                if provenance is not True:
                    result["checks"]["session_audit"] = "BLOCKING"
                    result["status"] = "INVALID"
                    result.setdefault("reasons", []).append(
                        "session audit: provenance unverified — "
                        "artifact body hash not found in OT stdout; "
                        "possible orchestrator-written artifact (FM-1)"
                    )
                    continue

            outcome = meta.get("outcome", "unverified")

            if outcome == "verified_match":
                result["checks"]["session_audit"] = "PASS"
                continue
            elif outcome in ("verified_mismatch", "unknown_model"):
                # Provider-level fallback (e.g., OpenRouter 400→other model)
                # is not a code defect — when allowed by policy, downgrade
                # from INVALID to PASS with a WARNING annotation.
                if (meta.get("fallback_detected") is True
                        and pipeline.get("timeout_policy", {}).get(
                            "allow_provider_fallback") is True):
                    result["checks"]["session_audit"] = "WARNING"
                    result.setdefault("reasons", []).append(
                        f"session audit: provider fallback detected — "
                        f"assigned={meta.get('assigned_model', '?')} "
                        f"actual={meta.get('actual_model', '?')} "
                        f"(allowed by allow_provider_fallback policy)"
                    )
                    continue
                result["checks"]["session_audit"] = "BLOCKING"
                result["status"] = "INVALID"
                result.setdefault("reasons", []).append(
                    f"session audit: {outcome} — "
                    f"assigned={meta.get('assigned_model', '?')} "
                    f"actual={meta.get('actual_model', '?')}"
                )
            else:
                # unverified, unavailable, exception, or unknown value
                result["checks"]["session_audit"] = "BLOCKING"
                result["status"] = "BLOCKING"
                result.setdefault("reasons", []).append(
                    f"session audit: {outcome} — audit could not verify "
                    f"model (reason: "
                    f"{meta.get('unverified_reason', meta.get('exception', 'unknown'))})"
                )
        except (json.JSONDecodeError, KeyError, OSError):
            result["checks"]["session_audit"] = "BLOCKING"
            result["status"] = "BLOCKING"
            result.setdefault("reasons", []).append(
                f"session audit: metadata file corrupted or unreadable "
                f"for phase '{art.phase}'"
            )


def cascade_invalidation(artifacts: List[Artifact],
                         artifact_results: Dict[str, Any]) -> None:
    """Unified invalidation cascade: any INVALID upstream → ALL dependents INVALID.

    Unlike the old propagate_fallback_to_descendants, this cascades ALL INVALID
    reasons (session_audit, stale, schema, input_linkage, etc.) transitively.
    A trust chain is only as strong as its weakest link — one broken upstream
    means every downstream artifact must be INVALID.
    """
    # Build reverse dependency map: input_sha → [dependent_sha, ...]
    dependents: Dict[str, List[str]] = {}
    for art in artifacts:
        for inp in art.inputs:
            if inp.resolved:
                dep_sha = inp.resolved.sha256
                if dep_sha not in dependents:
                    dependents[dep_sha] = []
                dependents[dep_sha].append(art.sha256)

    # Iterate until no new INVALID artifacts
    changed = True
    while changed:
        changed = False
        for dep_sha, result in list(artifact_results.items()):
            if result.get("status") != "INVALID":
                continue
            child_shas = dependents.get(dep_sha, [])
            for child_sha in child_shas:
                child_result = artifact_results.get(child_sha)
                if child_result and child_result.get("status") != "INVALID":
                    child_result["status"] = "INVALID"
                    child_result.setdefault("reasons", []).append(
                        "cascade: upstream artifact is INVALID — trust chain broken"
                    )
                    changed = True


def resolve_current_attempt(phase_names: List[str], phase_cfgs: Dict[str, Any],
                             latest_by_phase: Dict[str, Artifact],
                             by_phase: Dict[str, List[Artifact]],
                             artifact_results: Dict[str, Any]) -> Artifact:
    """Select current attempt by following transition chains from DAG-latest artifact.
    
    If the DAG-latest artifact is valid and routes backward (e.g. Review BLOCKING →
    establish), and the target phase has a newer valid artifact, switch to that
    artifact. Also handles INVALID artifacts by checking what they were trying to
    route to.
    """
    # Start from DAG-latest
    current_art: Optional[Artifact] = None
    for name in reversed(phase_names):
        if name in latest_by_phase:
            current_art = latest_by_phase[name]
            break
    assert current_art is not None

    phase_index = {n: i for i, n in enumerate(phase_names)}
    visited: set[str] = set()

    for _ in range(len(phase_names) * 2):
        if current_art.phase in visited:
            break
        visited.add(current_art.phase)

        result = artifact_results.get(current_art.sha256, {})
        status = result.get("status", "UNKNOWN")

        if status != "INVALID":
            # Valid artifact (PASS or BLOCKING) — this IS the current attempt.
            # Do NOT backtrack from valid artifacts just because the verdict
            # routes to a previous phase.
            break

        # INVALID artifact: try to find the real current attempt.
        # Look at what it was trying to route to.
        verdict = result.get("verdict")
        if not verdict:
            break
        phase_cfg = phase_cfgs.get(current_art.phase, {})
        verdicts = phase_cfg.get("verdicts", {})
        rule = verdicts.get(verdict) if isinstance(verdicts, dict) else None

        if not isinstance(rule, dict):
            break

        nxt = rule.get("next")
        if not nxt or nxt not in phase_index or nxt not in latest_by_phase:
            break

        nxt_idx = phase_index.get(nxt, -1)
        cur_idx = phase_index.get(current_art.phase, -1)

        if nxt_idx >= cur_idx:
            # Forward or same-phase — no earlier phase to backtrack to
            break

        # Backward transition: check if target phase has a valid artifact
        target = latest_by_phase.get(nxt)
        if target is None:
            break
        target_res = artifact_results.get(target.sha256, {})
        if target_res.get("status") in ("INVALID", "UNKNOWN", None):
            break

        # Valid backtrack: switch to target artifact (e.g. stale Review → new Establish v2)
        current_art = target

    return current_art


